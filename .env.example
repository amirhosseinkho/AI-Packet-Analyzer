# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=packet_analyzer
POSTGRES_USER=analyzer
POSTGRES_PASSWORD=analyzer_secret
DATABASE_URL=postgresql+asyncpg://analyzer:analyzer_secret@localhost:5432/packet_analyzer

# ─── Packet Capture ───────────────────────────────────────────────────────────
CAPTURE_INTERFACE=eth0
CAPTURE_FILTER=
CAPTURE_BUFFER_SIZE=65536
CAPTURE_BATCH_SIZE=100

# ─── AI / Anomaly Detection ───────────────────────────────────────────────────
ISOLATION_FOREST_CONTAMINATION=0.05
AUTOENCODER_EPOCHS=50
AUTOENCODER_BATCH_SIZE=64
AUTOENCODER_HIDDEN_DIM=32
MODEL_SAVE_PATH=./models

# ─── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Reporting ────────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports
